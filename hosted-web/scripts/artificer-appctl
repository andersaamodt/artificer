    ;;
  automation:upsert)
    shift 2
    automation_id=""
    workspace_id=""
    conversation_id=""
    automation_name=""
    prompt_text=""
    schedule_kind=""
    schedule_value=""
    enabled_value=""
    allow_self_reschedule=""
