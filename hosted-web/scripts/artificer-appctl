          ;;
        *)
          printf '%s\n' "artificer-appctl: unknown option for automation run-now: $1" >&2
          exit 1
          ;;
      esac
    done
    require_non_empty "--automation-id" "$automation_id"
    call_action "automation_run_now" \
      "automation_id" "$automation_id"
    exit $?
    ;;
  automation:delete)
    shift 2
    automation_id=""
    while [ "$#" -gt 0 ]; do
