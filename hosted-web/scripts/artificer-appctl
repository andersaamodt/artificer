          ;;
        *)
          printf '%s\n' "artificer-appctl: unknown option for automation toggle: $1" >&2
          exit 1
          ;;
      esac
    done
    require_non_empty "--automation-id" "$automation_id"
    require_non_empty "--enabled" "$enabled_value"
    call_action "automation_toggle" \
      "automation_id" "$automation_id" \
      "enabled" "$enabled_value"
    exit $?
    ;;
  automation:run-now)
    shift 2
    automation_id=""
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --automation-id)
