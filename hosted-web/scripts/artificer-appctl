    if [ "$sa_output_json" -eq 1 ]; then
      printf '%s\n' "$response"
      exit 0
    fi
    print_self_actuation_orchestrate_from_json "$response"
    exit 0
    ;;
  self-actuation:policy-get)
    shift 2
    workspace_id=""
