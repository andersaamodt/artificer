    if [ "$output_json" -eq 1 ]; then
      printf '%s\n' "$response"
      exit 0
    fi
    print_self_actuation_policy_from_json "$response"
    exit 0
    ;;
  self-actuation:audit)
    shift 2
    limit_value=""
    output_json=0
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --limit)
          [ "$#" -ge 2 ] || { printf '%s\n' "artificer-appctl: --limit requires a value" >&2; exit 1; }
