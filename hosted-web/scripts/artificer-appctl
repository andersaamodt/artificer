    if [ "$output_json" -eq 1 ]; then
      printf '%s\n' "$response"
      exit 0
    fi
    selected_topic=$(json_extract_field "topic" "$response" 2>/dev/null || true)
    learning_goals=$(json_extract_field "learning_goals" "$response" 2>/dev/null || true)
    misconceptions=$(json_extract_field "common_misconceptions" "$response" 2>/dev/null || true)
    assessment_checks=$(json_extract_field "assessment_checks" "$response" 2>/dev/null || true)
    practice_tasks=$(json_extract_field "practice_tasks" "$response" 2>/dev/null || true)
    content_text=$(json_extract_field "content" "$response" 2>/dev/null || true)
    if [ -n "$selected_topic" ]; then
      printf '%s\n\n%s\n\n%s\n\n%s\n\n%s\n\n%s\n' \
        "Teaching topic: $selected_topic" \
        "Learning goals: $learning_goals" \
        "Common misconceptions: $misconceptions" \
        "Assessment checks: $assessment_checks" \
        "Practice tasks: $practice_tasks" \
        "$content_text"
    else
      printf '%s\n' "$content_text"
    fi
    exit 0
    ;;
  automation:list)
    shift 2
    output_json=0
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --json)
          output_json=1
          shift 1
          ;;
        *)
          printf '%s\n' "artificer-appctl: unknown option for automation list: $1" >&2
          exit 1
          ;;
      esac
    done
    response=$(call_action "automations_state")
    if [ "$output_json" -eq 1 ]; then
      printf '%s\n' "$response"
      exit 0
    fi
    print_automations_from_json "$response"
    exit 0
    ;;
  automation:toggle)
    shift 2
    automation_id=""
    enabled_value=""
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --automation-id)
          [ "$#" -ge 2 ] || { printf '%s\n' "artificer-appctl: --automation-id requires a value" >&2; exit 1; }
          automation_id=$2
          shift 2
          ;;
        --enabled)
          [ "$#" -ge 2 ] || { printf '%s\n' "artificer-appctl: --enabled requires a value" >&2; exit 1; }
          enabled_value=$2
